# HTTP port for the local Outpost server (default: 3002).
OUTPOST_PORT=3002

# Workspace registry root; each child directory is one workspace (default: ./data/workspaces).
OUTPOST_WORKSPACES=./data/workspaces

# Optional legacy/single-vault path used for the default workspace; leave empty for registry mode.
OUTPOST_VAULT=

# Optional read-only Maildir root; when absent or unreadable, mail ingest stays empty and warns once.
OUTPOST_MAIL_DATA=

# Optional users.yaml path for the Profile API; when unset, profile endpoints report not configured.
OUTPOST_USERS=

# Optional Apache htpasswd file used by the password-change endpoint; when unset, it reports not configured.
OUTPOST_HTPASSWD=

# Optional Claude CLI executable or absolute path used by Copilot (default: claude).
OUTPOST_CLAUDE_BIN=claude

# Claude model passed to the Copilot CLI (default: claude-opus-4-8).
OUTPOST_COPILOT_MODEL=claude-opus-4-8

# Optional tmux session checked before Copilot falls back to the Claude CLI (default: outpost-copilot).
OUTPOST_COPILOT_TMUX=outpost-copilot

# Optional identity used only when the reverse proxy omits X-Remote-User; when unset,
# identity-gated endpoints (Copilot, Profile) return 401 without the header.
# For a single-user local install, set this to your own username.
OUTPOST_DEFAULT_USER=
